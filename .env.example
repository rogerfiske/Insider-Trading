# Insider Routines -- environment configuration.
#
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
#
# .env lives in the repo root and is loaded by agents/common.py at startup.

# -- REQUIRED -------------------------------------------------------------------

# Anthropic API key. Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Generic SMTP alert delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USE_SSL=
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Deprecated Gmail-specific email settings
# Gmail SMTP -- the address Ross sends from + a Google app password
# (NOT your regular Gmail password).
# Create an app password at: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where Ross sends alerts. Defaults to GMAIL_USER if left blank.
GMAIL_TO=


# -- SEC EDGAR ------------------------------------------------------------------

# SEC EDGAR official access.
# Required for SEC.gov fair-access identification.
# Recommended format:
# SEC_USER_AGENT=Insider-Trading Roger Fiske contact-email@example.com
SEC_USER_AGENT=

# Optional third-party SEC API account reference / future integration.
# These are not used by SEC.gov EDGAR official connectors unless code is later added.
SEC_API_IO_ACCOUNT_EMAIL=
SEC_API_IO_USERNAME=
SEC_API_IO_API_KEY=

# -- ETHERSCAN ------------------------------------------------------------------

# Etherscan account reference and API access.
# Maya uses ETHERSCAN_API_KEY for on-chain token transfer monitoring.
# Get a free key at: https://etherscan.io/apis
# Etherscan website username/email are optional local reference fields only.
ETHERSCAN_ACCOUNT_EMAIL=
ETHERSCAN_USERNAME=
ETHERSCAN_API_KEY=

# -- OPTIONAL -------------------------------------------------------------------

# Telegram delivery. Leave both blank to disable.
# Create a bot via @BotFather, get the token. Get your chat ID by messaging
# the bot then visiting: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- TUNING (defaults are sensible) --------------------------------------------

# Sophie consensus thresholds.
# Note: The original prompt references DELPHI_MIN_AGREE / DELPHI_WINDOW_DAYS
# in .env comments, but the code (sophie.py) reads SOPHIE_* variables.
# We use SOPHIE_* here to match the code.
SOPHIE_MIN_AGREE=2
SOPHIE_WINDOW_DAYS=14

# Janet portfolio drift thresholds.
JANET_MIN_DELTA_PCT=3
JANET_MIN_POSITION=0.02

# Ross dry-run mode. Set to true to prevent actual email/Telegram delivery.
ROSS_DRY_RUN=true

# Alert routing safety and policy controls.
# Enable/disable delivery channels independently.
ALERT_ENABLE_TELEGRAM=false
ALERT_ENABLE_EMAIL=false

# Minimum severity level to deliver alerts (INFO, WATCH, ACTIONABLE, URGENT).
ALERT_MIN_SEVERITY=WATCH

# Deduplication window in hours. Same ticker+direction within this window suppresses duplicate alerts.
ALERT_DEDUP_HOURS=24

# Maximum alerts to deliver per Ross run (rate limiting).
ALERT_MAX_PER_RUN=3

# Require human review before alert delivery (not yet implemented, reserved for future).
ALERT_REQUIRE_HUMAN_REVIEW=false

# -- ADVANCED (override models) ------------------------------------------------

# Override the Claude models used by scouts. Defaults from source prompt:
# Note: These model IDs are from the original prompt and may need verification
# against Anthropic's current model list before real operation.
# INSIDER_MODEL=claude-sonnet-4-5-20250929
# INSIDER_MODEL_FAST=claude-haiku-4-5-20250630
# INSIDER_MODEL_DEEP=claude-opus-4-7-20251020
