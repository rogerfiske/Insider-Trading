{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generic Ticker Monitoring Plan Schema",
  "description": "Reusable schema for ticker monitoring plans",
  "type": "object",
  "required": [
    "ticker",
    "cik",
    "generated_at",
    "baseline",
    "monitoring_categories"
  ],
  "properties": {
    "ticker": {"type": "string"},
    "cik": {"type": "string"},
    "company_name": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "checkpoint": {"type": "string"},
    "based_on": {"type": "string"},
    "baseline": {
      "type": "object",
      "description": "Approved baseline values from synthesis packet",
      "properties": {
        "insider_activity": {"type": "object"},
        "capital_structure": {"type": "object"},
        "official_10q_financials": {"type": ["object", "null"]},
        "clinical_status": {"type": ["object", "string"]},
        "business_status": {"type": ["object", "string"]},
        "institutional_visibility": {"type": "object"}
      }
    },
    "monitoring_categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "frequency", "data_source", "track_changes"],
        "properties": {
          "category": {"type": "string"},
          "frequency": {"type": "string"},
          "data_source": {"type": "string"},
          "baseline_values": {"type": "object"},
          "track_changes": {"type": "array", "items": {"type": "string"}},
          "alert_triggers": {"type": "array", "items": {"type": "string"}},
          "manual_steps": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_name": {"type": "string"},
          "source_type": {"type": "string"},
          "update_frequency": {"type": "string"},
          "url_pattern": {"type": "string"}
        }
      }
    }
  }
}
